# Jamf MCP Server Configuration
# Copy this file to .env and fill in your credentials
#
# cp .env.example .env
#

# Your Jamf Pro instance URL
JAMF_PRO_URL=https://yourcompany.jamfcloud.com

# OAuth Client Credentials
# Create these in Jamf Pro: Settings > System > API Roles and Clients
JAMF_PRO_CLIENT_ID=your-client-id-here
JAMF_PRO_CLIENT_SECRET=your-client-secret-here

JAMF_SECURITY_URL=https://api.wandera.com
JAMF_SECURITY_APP_ID=your-app-id-here
JAMF_SECURITY_APP_SECRET=your-app-id-here